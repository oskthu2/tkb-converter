            </xs:element>
            <xs:element name="prescriberComment" type="xs:string" minOccurs="0" maxOccurs="1" >
                <xs:annotation> <xs:documentation>Förskrivarens kommentar till farmaceut. <br/>Kommentaren skrivs ut på receptblanketten om e-receptet omvandlas till ett pappersrecept (dvs. skrivs ut på en receptblankett på apoteket)</xs:documentation> </xs:annotation>
            </xs:element>
