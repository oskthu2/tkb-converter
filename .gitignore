
# SoapUI workspace-filer med kolon i filnamnet (ogiltiga på Windows/macOS)
*:*-workspace.xml
# Generellt: inga filer med kolon i källkods-arkiv
source/**/*:*

# source/-kataloger: råutpackade zip-filer från Bitbucket — spåras ej i git
# (viktiga filer kopieras till input/files/ av IG Builder)
igs/*/source/

# Lokala build/temp-artefakter från IG Publisher (ska inte versioneras)
docker-build.log
igs/*/output/
igs/*/temp/
igs/*/template/
igs/*/input-cache/
igs/*/Requirements-fromNarrative.json

# Behåll qa-errors.json, men ignorera stora råloggar
igs/*/ig-publisher-logs/*.log
